BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# @username бота без @ (для возврата после оплаты)
BOT_USERNAME=your_bot_username
# Публичный URL Railway: https://your-app.up.railway.app
PUBLIC_BASE_URL=
# ЮKassa REST API (ЛК → Настройки → Ключи API)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_PATH=/yookassa/webhook
YOOKASSA_VAT_CODE=1
# 1 = чек в запросе оплаты (только если в ЛК схема «Платёж и чек одновременно»)
# YOOKASSA_SEND_RECEIPT=0
# Необязательно: код системы налогообложения для чека
# YOOKASSA_TAX_SYSTEM_CODE=1
ADMIN_IDS=123456789
